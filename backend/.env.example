# ExamBro backend — copy to backend/.env and fill. Key NAMES only here.

# ── Supabase (data layer: Postgres + Auth + Storage) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Bypasses RLS — backend only, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers (client-provided) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Writer model (Phase-0 bake-off winner; pin exact ID once picked) ──
# provider: anthropic | openai | google
WRITER_PROVIDER=google
WRITER_MODEL=gemini-3.0-pro
# Critic must be a DIFFERENT family from writer (non-negotiable)
CRITIC_PROVIDER=anthropic
CRITIC_MODEL=claude-opus-4-8
# News search runs on Claude (server-side web search tool)
NEWS_MODEL=claude-opus-4-8
# Image generation
IMAGE_MODEL=gpt-image-2

# ── Scheduler / trigger ──
# Bearer token for POST /trigger (external cron). Generate a long random string.
TRIGGER_TOKEN=
# In-process APScheduler for dev (true) vs external HTTP cron (false)
ENABLE_APSCHEDULER=true

# ── Email notifications (Resend) ──
RESEND_API_KEY=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

# ── Frontend base URL (links in notification emails) ──
DASHBOARD_BASE_URL=http://localhost:3000
