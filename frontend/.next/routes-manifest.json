    },
    {
      "page": "/insights",
      "regex": "^/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/insights(?:/)?$"
    },
    {
      "page": "/Insights",
      "regex": "^/Insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Insights(?:/)?$"
    },
    {
      "page": "/Login",
      "regex": "^/Login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Login(?:/)?$"
    },
    {
      "page": "/PostReview",
      "regex": "^/PostReview(?:/)?$",
